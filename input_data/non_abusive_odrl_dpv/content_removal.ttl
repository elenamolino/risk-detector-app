@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dpv-odrl: <https://w3id.org/dpv/odrl> .
@prefix dpv: <https://w3id.org/dpv> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix justifications: <https://w3id.org/dpv/justifications> .
@base <http://example.com> .

:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with a user data removal term" ;
    :policyGraph {
        :PermissionDeleteUserAccount a odrl:Permission ;
            dcterms:description "Provider can delete your account with at least 30 days of prior notice and with reasons" ;
            odrl:assignee :provider ;
            odrl:action dpv-odrl:Remove ;
            odrl:target :userData ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv:hasJustification ;
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand (
                    justifications:ConfidentialityObligationCompromised
                    justifications:UnlawfulActivityObjection
                )
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:action odrl:inform ;
                odrl:assignee :provider ;
                odrl:target :userData ;
                odrl:informedParty :customer ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:purpose ;
                    odrl:operator odrl:isA ;
                    odrl:rightOperand dpv:CommunicationForCustomerCare 
                ] ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:deliveryChannel ;
                    odrl:operator odrl:isAnyOf ;
                    odrl:rightOperand ( "email"^^xsd:string "inProductNotification"^^xsd:string )
                ] ;
            ] .

        :provider a dpv:ServiceProvider .
        :userData [
                a dpv:PersonalData ;
                skos:broader pd:EmailAddress 
            ] . 
        :customer a dpv:Customer
} .